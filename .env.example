# Neon Postgres connection string (Vercel Postgres / Neon dashboard)
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# Shared secret guarding write API routes (single-user app).
# Set the same value in the client env below so the app can send it.
APP_SECRET="change-me-to-a-long-random-string"
NEXT_PUBLIC_APP_SECRET="change-me-to-a-long-random-string"
